---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Lightbox from '../components/Lightbox.astro';
import { formatISODate } from '../utils/format';
import { getMetaDescription } from '../utils/excerpt';

const {
  entry,
  Content,
  typeLabel,
  headings = [],
  prev,
  next
} = Astro.props;

type TocHeading = {
  depth: number;
  slug: string;
  text: string;
};

const tags = entry?.data?.tags ?? [];
const defaultImage = '/og.svg';
const coverImage = entry?.data?.cover ?? null;
const ogImage = coverImage ?? defaultImage;
const description = getMetaDescription(entry);
const articleLead = entry?.data?.description ?? description;

const tocItems = (headings as TocHeading[])
  .filter((heading: TocHeading) => heading.depth === 2 || heading.depth === 3)
  .map((heading: TocHeading) => ({
    depth: heading.depth,
    slug: heading.slug,
    text: heading.text
  }));

const readableSource = entry.body
  .replace(/```[\s\S]*?```/g, ' ')
  .replace(/`[^`]*`/g, ' ')
  .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
  .replace(/\[[^\]]+\]\([^)]*\)/g, ' ')
  .replace(/<[^>]+>/g, ' ')
  .replace(/[#>*_~-]/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();

const cjkCount = Array.from(readableSource.matchAll(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}]/gu)).length;
const latinWordCount = readableSource
  .replace(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}]/gu, ' ')
  .split(/\s+/)
  .filter(Boolean)
  .length;
const readTimeMinutes = Math.max(1, Math.ceil((cjkCount + latinWordCount) / 320));

const articleFacts = [
  { label: '发布', value: formatISODate(entry.data.date) },
  { label: '阅读', value: `约 ${readTimeMinutes} 分钟` },
  ...(typeLabel ? [{ label: '栏目', value: typeLabel }] : []),
  ...(tocItems.length ? [{ label: '目录', value: `${tocItems.length} 节` }] : [])
];

---

<BaseLayout
  title={entry.data.title}
  description={description}
  image={ogImage}
  ogType="article"
  bodyClass="article-page immersive-page"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={entry.data.date.toISOString()} />
    {tags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>
  <div class="article-header reader-exit-anchor">
    <h1 class="page-title">{entry.data.title}</h1>
    <button
      id="reader-exit"
      class="icon-button reader-exit"
      type="button"
      aria-label="退出阅读"
      title="退出阅读"
      aria-hidden="true"
      tabindex="-1"
    >
      <Icon name="reader-exit" class="icon" />
    </button>
    <div class="meta-line meta-line--article">
      发布于：{formatISODate(entry.data.date)}
      <> · 约 {readTimeMinutes} 分钟阅读</>
      {typeLabel ? <> · <span class="tag">{typeLabel}</span></> : null}
    </div>
    {articleLead ? <p class="article-dek">{articleLead}</p> : null}
    <div class="article-facts" aria-label="文章信息">
      {articleFacts.map((item) => (
        <div class="article-facts__item">
          <span class="article-facts__label">{item.label}</span>
          <strong class="article-facts__value">{item.value}</strong>
        </div>
      ))}
    </div>
    {tags.length ? (
      <div class="article-tags" aria-label="文章标签">
        {tags.map((tag: string) => (
          <span class="article-tag">#{tag}</span>
        ))}
      </div>
    ) : null}
  </div>

  {tocItems.length ? (
    <nav class="article-toc" aria-label="目录">
      <details open data-article-toc>
        <summary>目录</summary>
        <ol class="article-toc__list">
          {tocItems.map((item: TocHeading) => (
            <li class={`article-toc__item article-toc__item--depth-${item.depth}`}>
              <a href={`#${item.slug}`}>{item.text}</a>
            </li>
          ))}
        </ol>
      </details>
    </nav>
  ) : null}

  <div class="prose">
    <Content />
  </div>
  {(prev || next) ? (
    <nav class="prev-next" aria-label="上一篇/下一篇">
      <div class="prev-next__item">
        {prev ? (
          <a class="prev-next__link prev-next__link--prev" href={prev.href} rel="prev">
            <span class="prev-next__label">上一篇</span>
            <span class="prev-next__title">{prev.title}</span>
          </a>
        ) : (
          <span class="prev-next__placeholder" aria-hidden="true"></span>
        )}
      </div>
      <div class="prev-next__item">
        {next ? (
          <a class="prev-next__link prev-next__link--next" href={next.href} rel="next">
            <span class="prev-next__label">下一篇</span>
            <span class="prev-next__title">{next.title}</span>
          </a>
        ) : (
          <span class="prev-next__placeholder" aria-hidden="true"></span>
        )}
      </div>
    </nav>
  ) : null}

  <Lightbox
    id="lightbox"
    label="图片预览"
    enableZoom={false}
    enablePan={false}
    enableSwipeDownClose={false}
  />

  <script>
    import { initArticleLightbox } from '../scripts/lightbox';

    initArticleLightbox({
      dialogId: 'lightbox',
      containerSelector: '.prose',
      enableZoom: false,
      enablePan: false,
      enableSwipeDownClose: false
    });
  </script>
  <script is:inline>
    (() => {
      const toc = document.querySelector('[data-article-toc]');
      if (!toc) return;

      const mq = window.matchMedia('(max-width: 640px)');
      const sync = () => {
        if (mq.matches) {
          toc.removeAttribute('open');
        } else {
          toc.setAttribute('open', '');
        }
      };

      sync();
      mq.addEventListener('change', sync);
    })();
  </script>
</BaseLayout>
